<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CbrToCbz.MainWindow"
        Title="CBR to CBZ Converter"
        Width="820" Height="660"
        MinWidth="600" MinHeight="480">

  <Window.Styles>

    <!-- Primary action button — uses system accent -->
    <Style Selector="Button.primary">
      <Setter Property="Theme" Value="{StaticResource AccentButtonTheme}"/>
      <Setter Property="Padding" Value="16,7"/>
    </Style>

    <!-- Secondary outlined button -->
    <Style Selector="Button.secondary">
      <Setter Property="Padding" Value="16,7"/>
    </Style>

    <!-- Destructive action button -->
    <Style Selector="Button.danger">
      <Setter Property="Foreground" Value="#C42B2B"/>
      <Setter Property="BorderBrush" Value="#C42B2B"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding" Value="16,7"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFF0F0"/>
    </Style>

  </Window.Styles>

  <DockPanel Margin="16">

    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Margin="0,4,0,14">
      <TextBlock Text="CBR → CBZ Converter"
                 FontSize="22" FontWeight="SemiBold"/>
      <TextBlock x:Name="ThreadInfoLabel"
                 FontSize="12" Opacity="0.55"
                 Margin="0,3,0,0"/>
    </StackPanel>

    <!-- Drop Zone -->
    <Border x:Name="DropZone"
            DockPanel.Dock="Top"
            BorderBrush="#B0B8C8" BorderThickness="2"
            CornerRadius="6"
            Padding="0,20" Margin="0,0,0,10"
            Cursor="Hand">
      <Border.Styles>
        <Style Selector="Border#DropZone">
          <Setter Property="Background" Value="#F6F8FB"/>
        </Style>
      </Border.Styles>
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
        <TextBlock Text="Drop .cbr files here"
                   FontSize="14" FontWeight="Medium"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="or use Add Files below"
                   FontSize="12" Opacity="0.5"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Action Buttons -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="6" Margin="0,0,0,10">
      <Button x:Name="StartButton"
              Classes="primary"
              Content="Convert"
              IsEnabled="False"
              Click="OnStartConversion"/>
      <Button x:Name="AddFilesButton"
              Classes="secondary"
              Content="Add Files…"
              Click="OnAddFiles"/>
      <Button x:Name="ClearButton"
              Classes="secondary"
              Content="Clear"
              Click="OnClearQueue"/>
      <Button x:Name="CancelButton"
              Classes="danger"
              Content="Cancel"
              IsVisible="False"
              Click="OnCancel"/>
    </StackPanel>

    <!-- File Queue -->
    <Border DockPanel.Dock="Top"
            BorderBrush="#DCDCDC" BorderThickness="1"
            CornerRadius="5" Margin="0,0,0,8"
            Height="165" ClipToBounds="True">
      <DataGrid x:Name="FileGrid"
                GridLinesVisibility="Horizontal"
                CanUserResizeColumns="True"
                CanUserSortColumns="False"
                IsReadOnly="True"
                HeadersVisibility="Column"
                BorderThickness="0">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Filename"  Binding="{Binding Filename}"  Width="*"/>
          <DataGridTextColumn Header="Path"      Binding="{Binding FullPath}"  Width="2*"/>
          <DataGridTemplateColumn Header="Status" Width="100">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Status}"
                           Foreground="{Binding StatusColor}"
                           FontWeight="{Binding StatusWeight}"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Options row -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="12" Margin="0,0,0,8">
      <CheckBox x:Name="DeleteOriginalCheckbox"
                Content="Delete originals after conversion"
                VerticalAlignment="Center"/>
      <Button x:Name="DeleteOriginalsButton"
              Classes="danger"
              Content="Delete Originals"
              IsEnabled="False"
              Click="OnDeleteOriginals"/>
    </StackPanel>

    <!-- Status strip -->
    <Border DockPanel.Dock="Top"
            CornerRadius="4" Padding="10,5"
            Margin="0,0,0,8">
      <Border.Styles>
        <Style Selector="Border">
          <Setter Property="Background" Value="#F0F2F5"/>
        </Style>
      </Border.Styles>
      <TextBlock x:Name="StatusLabel"
                 Text="Ready — drop files or click Add Files…"
                 FontSize="12" Opacity="0.7"/>
    </Border>

    <!-- Log -->
    <Border BorderBrush="#DCDCDC" BorderThickness="1"
            CornerRadius="5" ClipToBounds="True">
      <DockPanel>
        <Border DockPanel.Dock="Top"
                BorderBrush="#DCDCDC" BorderThickness="0,0,0,1"
                Padding="10,5">
          <Border.Styles>
            <Style Selector="Border">
              <Setter Property="Background" Value="#F5F5F5"/>
            </Style>
          </Border.Styles>
          <TextBlock Text="Log"
                     FontSize="11" FontWeight="SemiBold"
                     Opacity="0.6"/>
        </Border>
        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
          <TextBox x:Name="LogTextBox"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   BorderThickness="0"
                   FontFamily="Cascadia Code,Consolas,monospace"
                   FontSize="11"
                   Padding="10,8"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

  </DockPanel>
</Window>
