<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CbrToCbz.MainWindow"
        Title="CBR to CBZ Converter"
        Width="820" Height="660"
        MinWidth="600" MinHeight="480"
        Background="#F8F9FA">

  <Window.Styles>

    <!-- Primary: solid blue — must target ContentPresenter for background,
         FluentTheme ignores Background set on Button directly -->
    <Style Selector="Button.primary">
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius"    Value="5"/>
      <Setter Property="Padding"         Value="18,8"/>
      <Setter Property="FontWeight"      Value="Medium"/>
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter">
      <Setter Property="Background" Value="#2563EB"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1D4ED8"/>
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#1E40AF"/>
    </Style>
    <Style Selector="Button.primary:disabled">
      <Setter Property="Foreground" Value="#1D4ED8"/>
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#BFDBFE"/>
    </Style>

    <!-- Secondary: white background, gray border -->
    <Style Selector="Button.secondary">
      <Setter Property="Foreground"      Value="#374151"/>
      <Setter Property="BorderBrush"     Value="#D1D5DB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="5"/>
      <Setter Property="Padding"         Value="18,8"/>
    </Style>
    <Style Selector="Button.secondary /template/ ContentPresenter">
      <Setter Property="Background" Value="White"/>
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#F3F4F6"/>
    </Style>

    <!-- Danger: white with red text/border -->
    <Style Selector="Button.danger">
      <Setter Property="Foreground"      Value="#DC2626"/>
      <Setter Property="BorderBrush"     Value="#FCA5A5"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"    Value="5"/>
      <Setter Property="Padding"         Value="18,8"/>
    </Style>
    <Style Selector="Button.danger /template/ ContentPresenter">
      <Setter Property="Background" Value="White"/>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FEF2F2"/>
    </Style>
    <Style Selector="Button.danger:disabled">
      <Setter Property="Foreground" Value="#FCA5A5"/>
    </Style>
    <Style Selector="Button.danger:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFF1F2"/>
    </Style>

  </Window.Styles>

  <DockPanel Margin="20">

    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
      <TextBlock Text="CBR → CBZ Converter"
                 FontSize="20" FontWeight="SemiBold"
                 Foreground="#111827"/>
      <TextBlock x:Name="ThreadInfoLabel"
                 FontSize="12" Foreground="#6B7280"
                 Margin="0,3,0,0"/>
    </StackPanel>

    <!-- Drop Zone -->
    <Border x:Name="DropZone"
            DockPanel.Dock="Top"
            Background="White"
            BorderBrush="#D1D5DB" BorderThickness="2"
            CornerRadius="6"
            Padding="0,24" Margin="0,0,0,12"
            Cursor="Hand">
      <StackPanel HorizontalAlignment="Center" Spacing="4">
        <TextBlock Text="Drop .cbr files here"
                   FontSize="14" FontWeight="Medium"
                   Foreground="#374151"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="or use Add Files below"
                   FontSize="12" Foreground="#9CA3AF"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Action Buttons -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="8" Margin="0,0,0,12">
      <Button x:Name="StartButton"
              Classes="primary"
              Content="Convert"
              IsEnabled="False"
              Click="OnStartConversion"/>
      <Button x:Name="AddFilesButton"
              Classes="secondary"
              Content="Add Files…"
              Click="OnAddFiles"/>
      <Button x:Name="ClearButton"
              Classes="secondary"
              Content="Clear"
              Click="OnClearQueue"/>
      <Button x:Name="CancelButton"
              Classes="danger"
              Content="Cancel"
              IsVisible="False"
              Click="OnCancel"/>
    </StackPanel>

    <!-- File Queue -->
    <Border DockPanel.Dock="Top"
            Background="White"
            BorderBrush="#E5E7EB" BorderThickness="1"
            CornerRadius="6" Margin="0,0,0,10"
            Height="165" ClipToBounds="True">
      <DataGrid x:Name="FileGrid"
                Background="White"
                GridLinesVisibility="Horizontal"
                CanUserResizeColumns="True"
                CanUserSortColumns="False"
                IsReadOnly="True"
                HeadersVisibility="Column"
                BorderThickness="0"
                RowBackground="White">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Filename"  Binding="{Binding Filename}"  Width="*"/>
          <DataGridTextColumn Header="Path"      Binding="{Binding FullPath}"  Width="2*"/>
          <DataGridTemplateColumn Header="Status" Width="100">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Status}"
                           Foreground="{Binding StatusColor}"
                           FontWeight="{Binding StatusWeight}"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Options row -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="16" Margin="0,0,0,10"
                VerticalAlignment="Center">
      <CheckBox x:Name="DeleteOriginalCheckbox"
                Content="Delete originals after conversion"
                Foreground="#374151"
                FontSize="13"
                VerticalAlignment="Center"/>
      <Button x:Name="DeleteOriginalsButton"
              Classes="danger"
              Content="Delete Originals"
              IsEnabled="False"
              Click="OnDeleteOriginals"/>
    </StackPanel>

    <!-- Status strip -->
    <Border DockPanel.Dock="Top"
            Background="White"
            BorderBrush="#E5E7EB" BorderThickness="1"
            CornerRadius="5" Padding="12,7"
            Margin="0,0,0,10">
      <TextBlock x:Name="StatusLabel"
                 Text="Ready — drop files or click Add Files…"
                 FontSize="12" Foreground="#6B7280"/>
    </Border>

    <!-- Log -->
    <Border Background="White"
            BorderBrush="#E5E7EB" BorderThickness="1"
            CornerRadius="6" ClipToBounds="True">
      <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                Padding="12,6">
          <TextBlock Text="Log"
                     FontSize="12" FontWeight="SemiBold"
                     Foreground="#4B5563"/>
        </Border>
        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
          <TextBox x:Name="LogTextBox"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Background="White"
                   Foreground="#374151"
                   BorderThickness="0"
                   FontFamily="Cascadia Code,Consolas,monospace"
                   FontSize="11"
                   Padding="12,8"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

  </DockPanel>
</Window>
