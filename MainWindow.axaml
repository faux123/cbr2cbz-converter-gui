<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CbrToCbz"
        x:Class="CbrToCbz.MainWindow"
        Title="CBR to CBZ Converter"
        Width="800" Height="680"
        MinWidth="600" MinHeight="500"
        Background="#FAFAF9"
        FontFamily="Inter,Segoe UI,Ubuntu,sans-serif">

  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#C8821A"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="5"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#A06815"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#E1E1E0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="5"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#F0EFEE"/>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#D63030"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#D63030"/>
      <Setter Property="CornerRadius" Value="5"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>
  </Window.Styles>

  <DockPanel Margin="20">

    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <TextBlock FontSize="28" FontWeight="Bold">
        <Run Text="CBR to " Foreground="#1A1A1A"/>
        <Run Text="CBZ" Foreground="#C8821A"/>
        <Run Text=" Converter" Foreground="#1A1A1A"/>
      </TextBlock>
      <TextBlock x:Name="ThreadInfoLabel"
                 FontSize="13" Foreground="#888"
                 Margin="0,3,0,0"/>
    </StackPanel>

    <!-- Drop Zone -->
    <Border x:Name="DropZone"
            DockPanel.Dock="Top"
            BorderBrush="#C8821A" BorderThickness="2"
            CornerRadius="6" Background="#FDF3E3"
            Padding="20,22" Margin="0,0,0,12"
            Cursor="Hand">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="⬇  Drop .cbr files here"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="#C8821A"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="or use the Add Files… button below"
                   FontSize="12" Foreground="#999"
                   HorizontalAlignment="Center"
                   Margin="0,5,0,0"/>
      </StackPanel>
    </Border>

    <!-- Action Buttons -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="8" Margin="0,0,0,12">
      <Button x:Name="StartButton"
              Classes="primary"
              Content="Start Conversion"
              IsEnabled="False"
              Click="OnStartConversion"/>
      <Button x:Name="AddFilesButton"
              Classes="secondary"
              Content="Add Files…"
              Click="OnAddFiles"/>
      <Button x:Name="ClearButton"
              Classes="secondary"
              Content="Clear Queue"
              Click="OnClearQueue"/>
      <Button x:Name="CancelButton"
              Classes="danger"
              Content="Cancel"
              IsVisible="False"
              Click="OnCancel"/>
    </StackPanel>

    <!-- File Queue -->
    <Border DockPanel.Dock="Top"
            BorderBrush="#E1E1E0" BorderThickness="1"
            CornerRadius="6" Margin="0,0,0,10"
            Height="170" ClipToBounds="True">
      <DataGrid x:Name="FileGrid"
                Background="White"
                GridLinesVisibility="Horizontal"
                CanUserResizeColumns="True"
                CanUserSortColumns="False"
                IsReadOnly="True"
                HeadersVisibility="Column"
                BorderThickness="0">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Filename"  Binding="{Binding Filename}"  Width="*"/>
          <DataGridTextColumn Header="Full Path" Binding="{Binding FullPath}"  Width="2*"/>
          <DataGridTemplateColumn Header="Status" Width="110">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Status}"
                           Foreground="{Binding StatusColor}"
                           FontWeight="{Binding StatusWeight}"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Delete Options -->
    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="12" Margin="0,0,0,10">
      <CheckBox x:Name="DeleteOriginalCheckbox"
                Content="Delete original CBR files after successful conversion"
                FontSize="13"/>
      <Button x:Name="DeleteOriginalsButton"
              Classes="danger"
              Content="Delete Originals Now"
              IsEnabled="False"
              Click="OnDeleteOriginals"/>
    </StackPanel>

    <!-- Status Bar -->
    <Border DockPanel.Dock="Top"
            Background="#F0EFEE"
            CornerRadius="4" Padding="10,6"
            Margin="0,0,0,10">
      <TextBlock x:Name="StatusLabel"
                 Text="Ready — drop files or click Add Files…"
                 FontSize="13" Foreground="#555"/>
    </Border>

    <!-- Conversion Log -->
    <Border BorderBrush="#E1E1E0" BorderThickness="1"
            CornerRadius="6" ClipToBounds="True">
      <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#F5F4F3"
                BorderBrush="#E1E1E0" BorderThickness="0,0,0,1"
                Padding="10,6">
          <TextBlock Text="Conversion Log"
                     FontSize="12" FontWeight="SemiBold"
                     Foreground="#666"/>
        </Border>
        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
          <TextBox x:Name="LogTextBox"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Background="White"
                   BorderThickness="0"
                   FontFamily="monospace"
                   FontSize="11"
                   Foreground="#555"
                   Padding="10,8"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

  </DockPanel>
</Window>
